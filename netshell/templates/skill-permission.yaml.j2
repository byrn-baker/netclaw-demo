# NetShell Skill Policy: {{ skill_name }}
# Auto-generated from SKILL.md netshell: section
# DO NOT EDIT - regenerate with: python compile-policies.py

version: 1
skill: {{ skill_name }}
description: {{ skill_description | default('Skill policy for ' + skill_name) }}
generated_at: {{ generated_at }}

# MCP tool permissions for this skill
mcp_permissions:
{% for mcp in mcp_tools %}
  - mcp: {{ mcp.mcp }}
    allowed_tools:
{% for tool in mcp.tools %}
      - {{ tool }}
{% endfor %}
{% endfor %}

# ITSM approval requirement
approval_required: {{ approval_required | default(false) }}

# Effective permissions (resolved from MCP policies)
resolved_permissions:
{% for mcp in mcp_tools %}
{% for tool in mcp.tools %}
  - mcp: {{ mcp.mcp }}
    tool: {{ tool }}
    permission: {{ resolved.get(mcp.mcp + '.' + tool, {}).get('permission', 'allow') }}
    requires_approval: {{ resolved.get(mcp.mcp + '.' + tool, {}).get('requires_approval', false) }}
    audit_level: {{ resolved.get(mcp.mcp + '.' + tool, {}).get('audit_level', 'standard') }}
{% endfor %}
{% endfor %}
