{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://netclaw.dev/schemas/ocsf-api-activity.json",
  "title": "OCSF API Activity Event",
  "description": "Open Cybersecurity Schema Framework (OCSF) API Activity event for NetShell audit logging. Class UID: 4001",
  "type": "object",
  "required": [
    "class_uid",
    "category_uid",
    "activity_id",
    "time",
    "severity_id",
    "message",
    "status",
    "actor",
    "api",
    "metadata"
  ],
  "properties": {
    "class_uid": {
      "type": "integer",
      "const": 4001,
      "description": "OCSF class: API Activity"
    },
    "category_uid": {
      "type": "integer",
      "const": 4,
      "description": "OCSF category: Network Activity"
    },
    "activity_id": {
      "type": "integer",
      "enum": [1, 2, 3, 4, 5],
      "description": "1=Create, 2=Read, 3=Update, 4=Delete, 5=Other"
    },
    "time": {
      "type": "integer",
      "description": "Unix timestamp in milliseconds"
    },
    "severity_id": {
      "type": "integer",
      "enum": [0, 1, 2, 3, 4, 5],
      "description": "0=Unknown, 1=Info, 2=Low, 3=Medium, 4=High, 5=Critical"
    },
    "message": {
      "type": "string",
      "description": "Human-readable event description"
    },
    "status": {
      "type": "string",
      "enum": ["success", "failure", "blocked"],
      "description": "Outcome of the API activity"
    },
    "actor": {
      "type": "object",
      "required": ["user", "session_id"],
      "properties": {
        "user": {
          "type": "string",
          "description": "Skill name or 'agent'"
        },
        "session_id": {
          "type": "string",
          "description": "Session identifier"
        }
      }
    },
    "api": {
      "type": "object",
      "required": ["operation", "service"],
      "properties": {
        "operation": {
          "type": "string",
          "description": "Tool name (e.g., suzieq_show, aruba_create_vlan)"
        },
        "service": {
          "type": "string",
          "description": "MCP server name (e.g., suzieq-mcp, aruba-cx-mcp)"
        },
        "request": {
          "type": "object",
          "description": "Tool arguments (sanitized - no credentials)"
        },
        "response": {
          "type": "object",
          "description": "Tool response (truncated for large responses)"
        }
      }
    },
    "src_endpoint": {
      "type": "object",
      "properties": {
        "ip": {
          "type": "string",
          "description": "Source IP address"
        },
        "hostname": {
          "type": "string",
          "description": "Source hostname"
        }
      }
    },
    "dst_endpoint": {
      "type": "object",
      "properties": {
        "ip": {
          "type": "string",
          "description": "Destination IP address"
        },
        "hostname": {
          "type": "string",
          "description": "Destination hostname"
        },
        "port": {
          "type": "integer",
          "description": "Destination port"
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["version", "product"],
      "properties": {
        "version": {
          "type": "string",
          "const": "1.0.0",
          "description": "Audit log schema version"
        },
        "product": {
          "type": "object",
          "required": ["name", "version"],
          "properties": {
            "name": {
              "type": "string",
              "const": "NetShell"
            },
            "version": {
              "type": "string"
            }
          }
        },
        "policy": {
          "type": "string",
          "description": "Policy that matched this request"
        },
        "violation_reason": {
          "type": "string",
          "description": "Reason for blocking (if status=blocked)"
        }
      }
    }
  }
}
