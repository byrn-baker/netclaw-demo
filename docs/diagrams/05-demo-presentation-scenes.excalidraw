      "x": 10720,
      "y": 420,
      "width": 211.2,
      "height": 20,
      "text": "BGP Speaker (RFC 4271)",
      "fontSize": 16,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#862e9c"
    },
    {
