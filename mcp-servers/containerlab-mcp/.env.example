# ContainerLab MCP Server — environment configuration
# Copy to .env and fill in your values

# Colon-separated list of directories to scan for .clab.yml topology files
# Default scans the current directory
CLAB_MCP_TOPOLOGY_PATHS=.

# Log level: debug, info, warning, error
CLAB_MCP_LOG_LEVEL=info

# Remote SSH execution (leave empty for local execution)
# Format: user@host
CLAB_MCP_REMOTE=

# SSH private key path for remote execution
CLAB_MCP_SSH_KEY_PATH=

# SSH port for remote execution (default: 22)
CLAB_MCP_SSH_PORT=22

# Transport mode: stdio (default) or sse
CLAB_MCP_TRANSPORT=stdio

# Host/port for SSE transport mode (only used when transport=sse)
CLAB_MCP_HOST=0.0.0.0
CLAB_MCP_PORT=8080
